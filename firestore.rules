rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Cho phép tất cả mọi người đọc (Khách, Nhân viên)
      allow read: if true;
      // Chỉ cho phép người dùng đã Đăng nhập (Admin) được phép ghi, sửa, xóa
      allow write: if request.auth != null;
    }
  }
}
