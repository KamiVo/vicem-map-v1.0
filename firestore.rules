rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chỉ Admin UID cụ thể mới được write
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'Xq7aFcGB8YhkhNwJvQIZJIQSLE63';
    }

    // Dealers collection
    match /dealers/{dealerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      // Sub-collection: Sales
      match /sales/{yearId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      // Sub-collection: Products
      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // Audit Logs — chỉ Admin được tạo, không ai được sửa/xóa (bất biến)
    match /audit_logs/{logId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
