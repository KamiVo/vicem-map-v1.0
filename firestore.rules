rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Chỉ Admin UID cụ thể mới được write
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'nC9f8W8ktNYEDv1XOMSStSxgGpt1';
    }

    // Hàm kiểm tra cấu trúc dữ liệu Dealer hợp lệ
    function isValidDealer() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'lat', 'lng', 'status', 'createdAt'])
        && data.name is string
        && data.name.size() >= 3
        && data.lat is number
        && data.lng is number
        && data.status in ['Đại lý tốt', 'Đại lý chưa bán', 'Đại lý rủi ro', 'Không chào bán', 'Đặc biệt'];
    }

    // Dealers collection
    match /dealers/{dealerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDealer();
      allow update: if isAdmin(); // Cho phép update linh hoạt (ví dụ: update deleted=true)
      allow delete: if isAdmin();

      // Sub-collection: Sales
      match /sales/{yearId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }

      // Sub-collection: Products
      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if isAdmin();
      }
    }

    // Audit Logs — chỉ Admin được tạo, không ai được sửa/xóa (bất biến)
    match /audit_logs/{logId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
